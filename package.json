{
  "name": "servidor-notarias",
  "version": "1.0.2",
  "description": "Servidor local y panel de administración en Electron y Express para auditorías de capturas",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder build --windows",
    "server": "node backend/server.js"
  },
  "keywords": [
    "electron",
    "express",
    "mysql",
    "auditoria"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "multer": "^2.2.0",
    "mysql2": "^3.22.6",
    "pdf-lib": "^1.17.1"
  },
  "devDependencies": {
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.irec.servidornotarias",
    "productName": "ServidorNotarias",
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": "nsis"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Servidor Notarías"
    },
    "files": [
      "backend/**/*",
      "frontend/**/*",
      "main.js",
      "package.json"
    ]
  }
}
